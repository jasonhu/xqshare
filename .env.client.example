# xqshare 客户端环境变量配置
# 复制此文件为 .env 并修改配置
# cp .env.client.example .env

# ==================== 连接配置 ====================
# 服务端地址
XQSHARE_REMOTE_HOST=192.168.1.100

# 服务端端口
XQSHARE_REMOTE_PORT=18812

# ==================== 认证配置 ====================
# 客户端 ID（对应 clients.yaml 中的配置）
XQSHARE_CLIENT_ID=enterprise-user

# 客户端密钥
XQSHARE_CLIENT_SECRET=your-secret-here

# ==================== QMT 配置 ====================
# QMT 客户端 userdata_mini 目录路径
QMT_USERDATA_PATH=C:\QMT\userdata_mini

# 资金账号
QMT_ACCOUNT_ID=你的资金账号
