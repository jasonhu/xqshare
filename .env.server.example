# xqshare 服务端环境变量配置
# 复制此文件为 .env 并修改配置
# cp .env.server.example .env

# ==================== 服务配置 ====================
# 服务监听端口
XQSHARE_PORT=18812

# ==================== QMT 配置 ====================
# QMT 客户端 userdata_mini 目录路径
QMT_USERDATA_PATH=C:\QMT\userdata_mini

# 默认资金账号（可选）
QMT_ACCOUNT_ID=你的资金账号

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
